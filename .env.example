# Copy to .env and fill in the keys you want active.
# Providers with no key (or empty string) are automatically disabled.

# ── Provider API Keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Local LLM (Ollama / LM Studio / vLLM) ────────────────────────────────────
# Default: http://localhost:11434/v1 (Ollama). Set to empty string to disable.
AI_ROUTER_LOCAL_BASE_URL=http://localhost:11434/v1

# ── Routing strategy ──────────────────────────────────────────────────────────
# Options: anthropic | openai | gemini | local | weighted | round-robin
AI_ROUTER_MODE=weighted

# Seed for round-robin cold-start (which provider was used last)
AI_ROUTER_LAST_PROVIDER=openai

# ── Weights (for "weighted" mode) ─────────────────────────────────────────────
# Any positive numbers — auto-normalised. Missing = 1. Zero = skip.
AI_ROUTER_WEIGHT_ANTHROPIC=1
AI_ROUTER_WEIGHT_OPENAI=1
AI_ROUTER_WEIGHT_GEMINI=1
AI_ROUTER_WEIGHT_LOCAL=1

# ── Model overrides ───────────────────────────────────────────────────────────
AI_ROUTER_ANTHROPIC_MODEL=claude-opus-4-5
AI_ROUTER_OPENAI_MODEL=gpt-4o
AI_ROUTER_GEMINI_MODEL=gemini-2.0-flash
AI_ROUTER_LOCAL_MODEL=llama3.2

# ── Cache ─────────────────────────────────────────────────────────────────────
# How long (ms) to cache config before re-reading. 0 = always fresh.
AI_ROUTER_CACHE_TTL_MS=10000
